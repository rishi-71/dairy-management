// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id             String   @id @default(cuid())
  name           String
  mobile         String   @unique
  address        String   @db.Text
  isActive       Boolean  @default(true)
  openingBalance Float    @default(0.0)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions Subscription[]
  dailyLogs DailyLog[]
  extraLogs ExtraItemLog[]
}

model Item {
  id        String   @id @default(cuid())
  name      String
  price     Float
  unit      String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
  dailyLogs DailyLog[]
  extraLogs ExtraItemLog[]
}

model Subscription {
  id         String @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  itemId     String
  item       Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  customerName String @default("")
  itemName String @default("")
  
  morningQty Float @default(0.0)
  eveningQty Float @default(0.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, itemId])
}

model DailyLog {
  id    String  @id @default(cuid())
  dateStr String
  customerId  String
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  itemId  String
  item  Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  customerName String @default("")
  itemName String @default("")

  price Float @default(0.0)
  
  morningDelivered  Float @default(0.0)
  eveningDelivered  Float @default(0.0)

  createdAt DateTime  @default(now())
  updateAt  DateTime  @updatedAt

  @@unique([dateStr, customerId, itemId])
}

model ExtraItemLog {
  id           String   @id @default(cuid())
  dateStr      String
  
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  itemId       String
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  customerName String   @default("")
  itemName     String   @default("")
  price        Float    @default(0.0)
  quantity     Float    @default(1.0) // Extra item ki quantity
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Ek customer, ek din mein, same extra item ki ek hi entry rakhega (quantity update hogi)
  @@unique([dateStr, customerId, itemId])
}
